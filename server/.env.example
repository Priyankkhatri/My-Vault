# ─── Server Environment Variables ────────────────────────────────
# Copy this file to `.env` and fill in your values.

# Database
DATABASE_URL=postgresql://localhost:5432/myvault
# If you don't have PostgreSQL, the server falls back to in-memory SQLite-like storage for dev

# Auth
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-a-different-random-64-char-string

# Groq AI (free tier: console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Optional: Email alerts (defer to later phase)
# SENDGRID_API_KEY=
# ALERT_FROM_EMAIL=
