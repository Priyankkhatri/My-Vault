# ─── Server Environment Variables ────────────────────────────────
# Copy this file to `.env` and fill in your values.

# Database
DATABASE_URL=postgresql://localhost:5432/myvault
# If you don't have PostgreSQL, the server falls back to in-memory SQLite-like storage for dev

# Auth
JWT_SECRET=YOUR_JWT_SECRET
JWT_REFRESH_SECRET=YOUR_JWT_REFRESH_SECRET

# Groq AI (free tier: console.groq.com)
GROQ_API_KEY=YOUR_GROQ_API_KEY

# Supabase (for auth sync/proxy if needed)
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Optional: Email alerts (defer to later phase)
# SENDGRID_API_KEY=
# ALERT_FROM_EMAIL=
